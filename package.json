{
	"name": "obsidian-show-diff-enhanced",
	"version": "0.1.0",
	"description": "Render collapsible, side-by-side Git diffs in Obsidian",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [],
	"author": "Ivan Lednev; enhanced fork for Matheus Dias",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.28.1",
		"esbuild-plugin-svg": "^0.1.0",
		"esbuild-sass-plugin": "^3.7.0",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	},
	"dependencies": {
		"diff2html": "^3.4.56",
		"sass": "^1.62.0",
		"simple-git": "^3.36.0",
		"typed-assert": "^1.0.9"
	}
